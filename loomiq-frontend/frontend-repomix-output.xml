          value={stats.total_finished_goods}
          delta="12.4%"
          progress={82}
          barColor="#6B21A8"
          active={activeMetric === "goods"}
          onClick={() => setActiveMetric("goods")}
        />
        <KpiCard
          icon={Factory}
