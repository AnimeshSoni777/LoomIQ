    <BrowserRouter>
      <AppShell>
        <Routes>
          <Route path="/" element={<Dashboard />} />
          <Route path="/nl-query" element={<NlQuery />} />
          <Route path="/search" element={<ProductSearch />} />
          <Route path="/image-search" element={<ImageSearch />} />
          <Route path="/catalog" element={<FinishedGoodsExplorer />} />
        </Routes>
      </AppShell>
    </BrowserRouter>
  );
}
